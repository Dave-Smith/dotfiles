# Ignore everything by default
*

# Whitelist directories
!*/

# Ignore git repos in home
git

# Exclude installed tools
.cargo/
.bun/
go/

# Exclude temp
temp/

# Include these explicitly
!.gitconfig
!.gitignore
!.cargo/*
!.local/*
!.p10k.zsh
!.oh-my-zsh/**
!.tmux/*
!.tmux.conf
!.zshenv
!.zshrc

# Except these
.oh-my-zsh/.git
.tmux/plugins/tmux-resurrect
